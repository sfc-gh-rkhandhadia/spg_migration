# Copy this file to .env and fill in your values
# Never commit .env to git

# ── MSSQL (SQL Server) ────────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1434
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASE=MENU_MANAGEMENT

# ── Snowflake Postgres (SPG) ──────────────────────────────────────────────────
SPG_HOST=your-instance.snowflakecomputing.app
SPG_USER=snowflake_admin
SPG_PASSWORD=
SPG_DATABASE=postgres

# ── Paths ─────────────────────────────────────────────────────────────────────
MSSQL_SPG_SHARED_DIR=/path/to/shared-workflow
VALIDATION_OUTPUT_DIR=/path/to/output

# ── Report metadata ───────────────────────────────────────────────────────────
REPORT_CLIENT=Client Name
REPORT_AUTHOR=Your Name
